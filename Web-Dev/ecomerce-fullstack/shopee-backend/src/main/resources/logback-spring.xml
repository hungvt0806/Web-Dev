<?xml version="1.0" encoding="UTF-8"?>
<!--
  Logback configuration — production-grade structured logging.

  Profiles:
    dev  → coloured console output (human-readable)
    prod → JSON to stdout (parsed by Docker/log aggregator) + rolling file
    test → console only, WARN level

  Log files (prod):
    /var/log/shopee/app.log      — all logs (INFO+), rotated daily, 30-day retention
    /var/log/shopee/audit.log    — AUDIT logger only
    /var/log/shopee/error.log    — ERROR level only

  JSON fields (logstash-logback-encoder):
    @timestamp, level, logger, message, traceId, method, uri,
    clientIp, status, durationMs, thread, stack_trace
-->
<configuration scan="true" scanPeriod="30 seconds">

  <!-- ── Properties ──────────────────────────────────────── -->
  <property name="LOG_DIR"     value="${LOG_DIR:-/var/log/shopee}" />
  <property name="APP_NAME"    value="shopee-ecommerce" />

  <!-- ── Dev profile: coloured console ───────────────────── -->
  <springProfile name="dev">
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
        <pattern>%d{HH:mm:ss.SSS} %-5level [%X{traceId}] %logger{30} - %msg%n</pattern>
        <charset>UTF-8</charset>
      </encoder>
    </appender>

    <root level="INFO">
      <appender-ref ref="CONSOLE" />
    </root>

    <logger name="com.shopee.ecommerce" level="DEBUG" />
    <logger name="org.springframework.security"    level="INFO" />
    <logger name="org.hibernate.SQL"               level="DEBUG" />
    <logger name="org.springframework.web"         level="INFO" />
  </springProfile>

  <!-- ── Prod profile: JSON structured logs ───────────────── -->
  <springProfile name="prod">

    <!-- stdout JSON — consumed by Docker log driver / Fluentd -->
    <appender name="JSON_STDOUT" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="net.logstash.logback.encoder.LogstashEncoder">
        <includeMdcKeyName>traceId</includeMdcKeyName>
        <includeMdcKeyName>method</includeMdcKeyName>
        <includeMdcKeyName>uri</includeMdcKeyName>
        <includeMdcKeyName>clientIp</includeMdcKeyName>
        <includeMdcKeyName>status</includeMdcKeyName>
        <includeMdcKeyName>durationMs</includeMdcKeyName>
        <includeMdcKeyName>userId</includeMdcKeyName>
        <customFields>{"app":"${APP_NAME}","env":"prod"}</customFields>
        <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
          <maxDepthPerCause>20</maxDepthPerCause>
          <shortenedClassNameLength>20</shortenedClassNameLength>
        </throwableConverter>
      </encoder>
    </appender>

    <!-- Rolling file — daily rotation, 30-day retention, 1 GB max total -->
    <appender name="ROLLING_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
      <file>${LOG_DIR}/app.log</file>
      <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
        <fileNamePattern>${LOG_DIR}/app.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
        <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
          <maxFileSize>100MB</maxFileSize>
        </timeBasedFileNamingAndTriggeringPolicy>
        <maxHistory>30</maxHistory>
        <totalSizeCap>1GB</totalSizeCap>
      </rollingPolicy>
      <encoder class="net.logstash.logback.encoder.LogstashEncoder">
        <customFields>{"app":"${APP_NAME}","env":"prod"}</customFields>
      </encoder>
    </appender>

    <!-- Audit log — separate file for compliance -->
    <appender name="AUDIT_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
      <file>${LOG_DIR}/audit.log</file>
      <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
        <fileNamePattern>${LOG_DIR}/audit.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
        <maxHistory>90</maxHistory>
      </rollingPolicy>
      <encoder class="net.logstash.logback.encoder.LogstashEncoder">
        <customFields>{"app":"${APP_NAME}","log_type":"audit"}</customFields>
      </encoder>
    </appender>

    <!-- Error log — errors only for quick alerting -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
      <file>${LOG_DIR}/error.log</file>
      <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
        <level>ERROR</level>
      </filter>
      <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
        <fileNamePattern>${LOG_DIR}/error.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
        <maxHistory>30</maxHistory>
      </rollingPolicy>
      <encoder class="net.logstash.logback.encoder.LogstashEncoder">
        <customFields>{"app":"${APP_NAME}","log_type":"error"}</customFields>
      </encoder>
    </appender>

    <!-- Async wrappers — never block app threads on I/O -->
    <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
      <queueSize>2048</queueSize>
      <discardingThreshold>0</discardingThreshold>
      <neverBlock>false</neverBlock>
      <appender-ref ref="ROLLING_FILE" />
    </appender>

    <appender name="ASYNC_AUDIT" class="ch.qos.logback.classic.AsyncAppender">
      <queueSize>512</queueSize>
      <discardingThreshold>0</discardingThreshold>
      <appender-ref ref="AUDIT_FILE" />
    </appender>

    <!-- AUDIT logger — separate file, does not bubble up to root -->
    <logger name="AUDIT" level="INFO" additivity="false">
      <appender-ref ref="ASYNC_AUDIT" />
      <appender-ref ref="JSON_STDOUT" />
    </logger>

    <!-- Application loggers -->
    <logger name="com.shopee.ecommerce"         level="INFO" />
    <logger name="org.springframework.security" level="WARN" />
    <logger name="org.hibernate.SQL"            level="WARN" />

    <root level="WARN">
      <appender-ref ref="JSON_STDOUT" />
      <appender-ref ref="ASYNC_FILE" />
      <appender-ref ref="ERROR_FILE" />
    </root>
  </springProfile>

  <!-- ── Test profile ────────────────────────────────────── -->
  <springProfile name="test">
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
        <pattern>%d{HH:mm:ss} %-5level %logger{20} - %msg%n</pattern>
      </encoder>
    </appender>
    <root level="WARN">
      <appender-ref ref="CONSOLE" />
    </root>
    <logger name="com.shopee.ecommerce" level="INFO" />
  </springProfile>

</configuration>
